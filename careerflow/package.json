{
  "name": "careerflow",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A full-stack job search command center with explainable resume matching.",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "tsc -p tsconfig.server.json && vite build",
    "start": "node server-dist/index.js",
    "test": "node --import tsx --test --test-reporter=spec tests/*.test.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "express": "^5.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
